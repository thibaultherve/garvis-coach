# === Garmin Connect ===
GARMIN_EMAIL=your.email@example.com
GARMIN_PASSWORD=your_password

# === InfluxDB ===
INFLUXDB_HOST=influxdb
INFLUXDB_PORT=8086
INFLUXDB_DATABASE=GarminStats
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=change_me

# === Grafana ===
GRAFANA_URL=http://grafana:3000
GRAFANA_TOKEN=glsa_your_token_here

# === Athlete physiological parameters ===
# Used by garmin-toolbox for training load calculations.
# Find yours in Garmin Connect > Settings > User Settings > Heart Rate Zones.
ATHLETE_HR_MAX=190
ATHLETE_HR_REST=50
# Optional (auto-detected from Garmin if available):
# ATHLETE_LTHR=170
# ATHLETE_FTP=250

# === Location (for weather in activity dumps) ===
# Optional. GPS coordinates of your usual training area.
# ATHLETE_LAT=48.85
# ATHLETE_LON=2.35

# === External APIs (optional) ===
# OpenRouteService API key for route surface analysis
# ORS_API_KEY=your_key

# === Port overrides (optional) ===
# INFLUXDB_EXTERNAL_PORT=8087
# GRAFANA_PORT=3000
# MCP_COACH_PORT=8765
# MCP_TOOLBOX_PORT=8770
# MCP_GRAFANA_PORT=8768
