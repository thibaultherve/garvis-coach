          "alias": "Cadence (spm)",
          "measurement": "ActivityGPS",
          "policy": "default",
          "resultFormat": "time_series",
          "orderByTime": "ASC",
          "query": "SELECT mean(\"Cadence\") * 2 AS \"Cadence (spm)\" FROM \"ActivityGPS\" WHERE $timeFilter AND \"ActivitySelector\" =~ /running/ AND \"Cadence\" > 60 GROUP BY time(1d) fill(null)",
          "rawQuery": true,
          "groupBy": [],
          "tags": []
        }
